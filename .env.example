# === 微信AI机器人 配置 ===

# LLM 提供商: deepseek / mimo
LLM_PROVIDER=deepseek

# API Key (DeepSeek 或 MiMo Token Plan)
LLM_API_KEY=sk-your-api-key

# 模型名称 (不填则使用默认值)
# DeepSeek: deepseek-chat / deepseek-reasoner
# MiMo:     mimo-v2.5-pro
LLM_MODEL=

# API 地址 (不填则根据 provider 自动选择)
# DeepSeek: https://api.deepseek.com
# MiMo:     https://token-plan-cn.xiaomimimo.com/v1
LLM_BASE_URL=

# 风控参数
MAX_MSG_PER_HOUR=20              # 每群每小时最多AI回复
MAX_MSG_PER_MINUTE=5
MIN_MSG_INTERVAL=2               # 最短延迟(秒)
MAX_MSG_INTERVAL=5               # 最长延迟(秒)
RANDOM_SKIP_RATE=0.1             # 随机不回复概率(0-1, 0.1=10%)
WORK_START_HOUR=8                # 工作开始时间
WORK_END_HOUR=23                 # 工作结束时间
MAX_DAILY_ROUNDS=200             # 每日全局最大回复
COOLDOWN_MINUTES=1               # AI回复后冷却(分钟)

BOT_NAME=风笙
BOT_PERSONALITY=你是一个友善的微信群助手，回复简短自然，每次风格不同。

# Web 管理后台
WEB_PORT=3080                    # Web管理端口
JWT_SECRET=change-this-to-a-random-string  # JWT密钥(务必修改)
JWT_EXPIRE_HOURS=24              # Token过期时间(小时)
ADMIN_USERNAME=admin             # 管理员用户名
ADMIN_PASSWORD=admin123          # 管理员密码(务必修改)
LOCAL_AUTH_BYPASS=true           # 本地访问免认证(true/false)

# 看门狗
WATCHDOG_ENABLED=true            # 启用看门狗(true/false)
WATCHDOG_CHECK_INTERVAL=30       # 检查间隔(秒)
WATCHDOG_MAX_FAILURES=3          # 最大连续失败次数
